{
  "name": "WindHorseGame",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "start": "NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server",
    "build": "NODE_OPTIONS=--openssl-legacy-provider NODE_ENV=production webpack && node scripts/inline-gas-html.js",
    "check-login": "clasp show-authorized-user --json | grep -q '\"loggedIn\": true' || (echo 'Not logged in. Run: npm run login' >&2 && false)",
    "login": "clasp login",
    "logout": "clasp logout",
    "pull": "npm run check-login && git pull --rebase && clasp pull",
    "push": "npm run check-login && git push --force-with-lease && npm run build && clasp push",
    "deploy": "npm run check-login && DEPLOY_DATE=$(date \"+%Y-%m-%d %H:%M\") npm run build && clasp push && (ID=$(clasp list-deployments | awk '/@[0-9]/{print $2}' | tail -1); if [ -n \"$ID\" ]; then clasp update-deployment \"$ID\"; else clasp create-deployment; fi)",
    "open": "npm run check-login && clasp open-script",
    "setup": "clasp create --type webapp --title WindHorseGame --rootDir gas",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.9.0",
    "@google/clasp": "^3.3.0",
    "@types/classnames": "^2.3.4",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^29.7.0",
    "classnames": "^2.5.1",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^6.10.1",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-import": "^2.27.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-promise": "^5.2.0",
    "eslint-plugin-react": "^7.27.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-standard": "^5.0.0",
    "husky": "^4.2.5",
    "jest": "^29.7.0",
    "lint-staged": "^10.1.3",
    "prettier": "^2.0.4",
    "raw-loader": "^4.0.2",
    "stylelint": "^13.3.2",
    "stylelint-config-recommended": "^3.0.0",
    "stylelint-config-standard": "^20.0.0",
    "typescript": "^6.0.3",
    "webpack-dev-server": "^3.10.3"
  },
  "dependencies": {
    "@babel/preset-env": "^7.9.5",
    "@babel/preset-react": "^7.9.4",
    "babel-loader": "^8.1.0",
    "css-loader": "^3.5.2",
    "html-webpack-plugin": "^4.2.0",
    "prop-types": "^15.7.2",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-router-dom": "^5.1.2",
    "react-use": "^15.3.4",
    "sass": "^1.0.0",
    "sass-loader": "^8.0.2",
    "style-loader": "^1.1.4",
    "webpack": "^4.42.1",
    "webpack-cli": "^3.3.11",
    "zustand": "^4.5.7"
  }
}
