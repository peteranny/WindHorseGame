{
  "name": "WindHorseGame",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "start": "NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server",
    "build": "NODE_OPTIONS=--openssl-legacy-provider NODE_ENV=production webpack && node scripts/inline-gas-html.js",
    "check-login": "clasp show-authorized-user --json | grep -q '\"loggedIn\": true' || (echo 'Not logged in. Run: npm run login' >&2 && false)",
    "login": "clasp login",
    "logout": "clasp logout",
    "pull": "npm run check-login && git pull --rebase && clasp pull",
    "push": "npm run check-login && git push --force-with-lease && npm run build && clasp push",
    "deploy": "npm run check-login && npm run build && clasp push && (ID=$(clasp list-deployments | awk '/@[0-9]/{print $2}' | tail -1); if [ -n \"$ID\" ]; then clasp update-deployment \"$ID\"; else clasp create-deployment; fi)",
    "open": "npm run check-login && clasp open-script",
    "setup": "clasp create --type webapp --title WindHorseGame --rootDir gas"
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "babel-eslint": "^10.1.0",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.10.1",
    "eslint-config-standard": "^14.1.1",
    "eslint-plugin-import": "^2.20.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.1.2",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-react": "^7.19.0",
    "eslint-plugin-react-hooks": "^3.0.0",
    "eslint-plugin-standard": "^4.0.1",
    "husky": "^4.2.5",
    "lint-staged": "^10.1.3",
    "prettier": "^2.0.4",
    "stylelint": "^13.3.2",
    "stylelint-config-recommended": "^3.0.0",
    "stylelint-config-standard": "^20.0.0",
    "webpack-dev-server": "^3.10.3"
  },
  "dependencies": {
    "@babel/preset-env": "^7.9.5",
    "@babel/preset-react": "^7.9.4",
    "babel-loader": "^8.1.0",
    "classnames": "^2.2.6",
    "css-loader": "^3.5.2",
    "html-webpack-plugin": "^4.2.0",
    "sass": "^1.0.0",
    "prop-types": "^15.7.2",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-router-dom": "^5.1.2",
    "react-use": "^15.3.4",
    "sass-loader": "^8.0.2",
    "style-loader": "^1.1.4",
    "webpack": "^4.42.1",
    "webpack-cli": "^3.3.11"
  }
}
